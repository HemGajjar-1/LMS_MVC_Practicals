@model Practical_14.Models.DTOs.EmployeeDto

@{
    ViewBag.Title = "Delete";
}

<div class="container mt-4">
    <h2 class="mb-4">Delete Employee</h2>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">Are you sure you want to delete this employee?</h5>

            <p>
                <strong>Name:</strong> @Model.Name
            </p>

            <p>
                <strong>DOB:</strong> @Model.DOB.ToShortDateString()
            </p>

            <p>
                <strong>Age:</strong> @Model.Age
            </p>

            @using (Html.BeginForm())
            {
                @Html.HiddenFor(x => x.Id)

                <input type="submit"
                       value="Delete"
                       class="btn btn-dark" />

                @Html.ActionLink(
                    "Back to List",
                    "Index",
                    null,
                    new { @class = "btn btn-dark ms-2" })
            }
        </div>
    </div>
</div>