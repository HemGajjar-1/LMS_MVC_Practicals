@model Practical_12_Test_3.Models.Entity.EmployeeSearchViewModel

@{
    ViewBag.Title = "Search Employee";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>Search Employee By Designation</h2>
  

    @using (Html.BeginForm())
    {
        <div class="mb-3">

            <label>Designation</label>

            @Html.DropDownListFor(
                x => x.DesignationId,
                Model.Designations,
                "-- Select Designation --",
                new { @class = "form-control" })

        </div>

        <button type="submit"
                class="btn btn-dark">
            Search
        </button>
    }

    <hr />

    @if (Model.Employees != null)
    {
        <table class="table table-bordered">

            <tr>
                <th>Id</th>
                <th>First Name</th>
                <th>Middle Name</th>
                <th>Last Name</th>
                <th>DOB</th>
                <th>Mobile</th>
                <th>Address</th>
                <th>Salary</th>
            </tr>

            @foreach (var item in Model.Employees)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FirstName</td>
                    <td>@item.MiddleName</td>
                    <td>@item.LastName</td>
                    <td>@item.DOB.ToShortDateString()</td>
                    <td>@item.MobileNumber</td>
                    <td>@item.Address</td>
                    <td>@item.Salary</td>
                </tr>
            }

        </table>
    }

</div>