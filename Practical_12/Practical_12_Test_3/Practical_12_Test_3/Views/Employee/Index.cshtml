@model List<Practical_12_Test_3.Models.Employee>

@{
    ViewBag.Title = "Employee List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>Employee List</h2>

    <p>
      

        <div class="mb-3">
            @Html.ActionLink("Add Employee", "CreateEmployee", null,
                new { @class = "btn btn-dark me-2 mb-2" })

            @Html.ActionLink("Add Designation", "CreateDesignation", null,
                new { @class = "btn btn-dark me-2 mb-2" })

            @Html.ActionLink("Search Employee", "SearchByDesignation", null,
                new { @class = "btn btn-dark me-2 mb-2" })

            @Html.ActionLink("Employee & Designation", "EmployeeDesignationReport", null,
                new { @class = "btn btn-dark me-2 mb-2" })

            @Html.ActionLink("Designation Count", "DesignationCountReport", null,
                new { @class = "btn btn-dark me-2 mb-2" })

            @Html.ActionLink("More Than 1 Employee", "MultipleEmployeeDesignationReport", null,
                new { @class = "btn btn-dark me-2 mb-2" })

            @Html.ActionLink("Max Salary Employee", "MaxSalaryEmployee", null,
                new { @class = "btn btn-dark me-2 mb-2" })
        </div>

    </p>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>First Name</th>
                <th>Middle Name</th>
                <th>Last Name</th>
                <th>Designation</th>
                <th>DOB</th>
                <th>Mobile</th>
                <th>Address</th>
                <th>Salary</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FirstName</td>
                    <td>@item.MiddleName</td>
                    <td>@item.LastName</td>
                    <td>@item.Designation</td>
                    <td>@item.DOB.ToShortDateString()</td>
                    <td>@item.MobileNumber</td>
                    <td>@item.Address</td>
                    <td>@item.Salary</td>
                </tr>
            }

        </tbody>

    </table>

</div>