@model List<Practical_12_Test_1.Models.Entity.Employee>

<div class="container mt-4">

    <h3 class="text-dark fw-bold border-bottom border-dark pb-2">Employee List</h3>
    <table class="table table-bordered border-dark m-0">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>First Name</th>
                <th>Middle Name</th>
                <th>Last Name</th>
                <th>DOB</th>
                <th>Mobile</th>
                <th>Address</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FirstName</td>
                    <td>@item.MiddleName</td>
                    <td>@item.LastName</td>
                    <td>@item.DOB.ToShortDateString()</td>
                    <td>@item.MobileNumber</td>
                    <td>@item.Address</td>
                </tr>
            }
        </tbody>
    </table>

    <br /><br />

    <h3 class="text-dark fw-bold border-bottom border-dark pb-2">Add Employee</h3>
    @using (Html.BeginForm("Create", "Employee", FormMethod.Post))
    {
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label fw-bold">First Name</label>
                @Html.TextBox("FirstName", null, new { @class = "form-control border-dark" })
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Middle Name</label>
                @Html.TextBox("MiddleName", null, new { @class = "form-control border-dark" })
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Last Name</label>
                @Html.TextBox("LastName", null, new { @class = "form-control border-dark" })
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">DOB</label>
                @Html.TextBox("DOB", null, new { @class = "form-control border-dark", type = "date" })
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Mobile</label>
                @Html.TextBox("MobileNumber", null, new { @class = "form-control border-dark" })
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Address</label>
                @Html.TextBox("Address", null, new { @class = "form-control border-dark" })
            </div>
        </div>
        <br />
        <button type="submit" class="btn btn-dark fw-bold">Insert Record</button>
    }

    <br /><br />

    <h3 class="text-dark fw-bold border-bottom border-dark pb-2">Bulk Operations</h3>
    <div class="d-flex gap-2">
        @Html.ActionLink("Update First Name", "UpdateFirstName", "Employee", null, new { @class = "btn btn-outline-dark fw-bold", onclick = "return confirm('Update first record?')" })
        @Html.ActionLink("Update Middle Name", "UpdateMiddleName", "Employee", null, new { @class = "btn btn-outline-dark fw-bold", onclick = "return confirm('Update all middle names?')" })
        @Html.ActionLink("Delete Id < 2", "DeleteLessThanTwo", "Employee", null, new { @class = "btn btn-outline-dark fw-bold", onclick = "return confirm('Delete where ID < 2?')" })
        @Html.ActionLink("Delete All Data", "DeleteAll", "Employee", null, new { @class = "btn btn-outline-dark fw-bold", onclick = "return confirm('Delete everything?')" })
    </div>

</div>