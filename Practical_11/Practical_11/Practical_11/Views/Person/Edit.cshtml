
@{
    ViewBag.Title = "Edit";
}

@model Practical_11.Models.Entity.Person
<h2 class="text-center my-4">Edit Person</h2>

<div class="container d-flex justify-content-center">

    <div class="card shadow border-0 p-4"
         style="width: 330px; border-radius: 12px;">

        @using (Html.BeginForm())
        {
            @Html.HiddenFor(x => x.Id)

            <div class="mb-3">

                <label class="form-label fw-bold">
                    Name
                </label>

                @Html.TextBoxFor(
                    x => x.Name,
                    new
                    {
                        @class = "form-control"
                    })

            </div>

            <div class="mb-3">

                <label class="form-label fw-bold">
                    DOB
                </label>

                @Html.TextBoxFor(
                    x => x.DOB,
                    "{0:yyyy-MM-dd}",
                    new
                    {
                        @class = "form-control",
                        type = "date"
                    })

            </div>

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Address
                </label>

                @Html.TextBoxFor(
                    x => x.Address,
                    new
                    {
                        @class = "form-control"
                    })

            </div>

            <div class="text-center">

                <button type="submit"
                        class="btn btn-dark w-100 ">
                    Update
                </button>

            </div>
        }

    </div>

</div>