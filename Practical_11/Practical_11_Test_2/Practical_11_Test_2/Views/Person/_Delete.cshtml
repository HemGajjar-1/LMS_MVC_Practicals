
@{
    ViewBag.Title = "_Delete";
}
@model Practical_11_Test_2.Models.Entity.Person
<h5 class="text-center">(Partial View)</h5>

<div class="container d-flex justify-content-center">

    <div class="card shadow border-0 p-4"
         style="width: 330px; border-radius: 12px;">

        <h5 class="text-center mb-4">
            Are you sure you want to delete this person?
        </h5>

        @using (Html.BeginForm())
        {
            @Html.HiddenFor(x => x.Id)

            <div class="mb-3">

                <label class="form-label fw-bold">
                    Name
                </label>

                <input type="text"
                       class="form-control"
                       value="@Model.Name"
                       readonly />

            </div>

            <div class="mb-3">

                <label class="form-label fw-bold">
                    DOB
                </label>

                <input type="text"
                       class="form-control"
                       value="@Model.DOB"
                       readonly />

            </div>

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Address
                </label>

                <input type="text"
                       class="form-control"
                       value="@Model.Address"
                       readonly />

            </div>

            <div class="text-center">

                <button type="submit"
                        class="btn btn-dark px-5">
                    Delete
                </button>

            </div>
        }

    </div>

</div>
