@model Practical_13_Part2.Models.DTOs.DesignationDto

@{
    ViewBag.Title = "Create Designation";
}

<div class="container mt-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="bg-dark text-white p-4">
            <h2 class="mb-0 fw-bold">Create Designation</h2>
        </div>

        <div class="card-body p-5">

            @using (Html.BeginForm())
            {
                <div class="mb-4">
                    <label class="form-label fw-semibold">Designation Name</label>

                    @Html.TextBoxFor(x => x.DesignationName,
                        new
                        {
                            @class = "form-control form-control-lg rounded-3",
                            placeholder = "Enter designation name"
                        })
                </div>

                <div class="d-flex gap-3">
                    <input type="submit"
                           value="Save Designation"
                           class="btn btn-dark btn-lg px-4 rounded-3" />

                    @Html.ActionLink(
                        "Back to List",
                        "Index",
                        null,
                        new
                        {
                            @class = "btn btn-outline-dark btn-lg px-4 rounded-3"
                        })
                </div>
            }

        </div>
    </div>
</div>