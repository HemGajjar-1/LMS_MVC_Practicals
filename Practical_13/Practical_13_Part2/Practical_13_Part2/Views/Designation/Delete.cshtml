@model Practical_13_Part2.Models.DTOs.DesignationDto

@{
    ViewBag.Title = "Delete Designation";
}

<div class="container mt-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="bg-dark text-white p-4">
            <h2 class="mb-0 fw-bold">Delete Designation</h2>
        </div>

        <div class="card-body p-5">

            <div class="mb-4">
                <h5 class="mb-0">Are you sure you want to delete this designation?</h5>
            </div>

            @using (Html.BeginForm())
            {
                @Html.HiddenFor(x => x.Id)

                <div class="mb-4">
                    <label class="form-label fw-semibold">Designation Name</label>

                    <input type="text"
                           class="form-control form-control-lg rounded-3"
                           value="@Model.DesignationName"
                           readonly />
                </div>

                <div class="d-flex gap-3">
                    <input type="submit"
                           value="Delete"
                           class="btn btn-dark btn-lg px-4 rounded-3" />

                    @Html.ActionLink(
                        "Back to List",
                        "Index",
                        null,
                        new
                        {
                            @class = "btn btn-outline-dark btn-lg px-4 rounded-3"
                        })
                </div>
            }

        </div>
    </div>
</div>