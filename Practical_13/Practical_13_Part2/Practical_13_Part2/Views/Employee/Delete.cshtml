@model Practical_13_Part2.Models.DTOs.EmployeeFormDto

@{
    ViewBag.Title = "Delete Employee";
}

<div class="container mt-5">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="bg-dark text-white p-4">
            <h2 class="mb-0 fw-bold">Delete Employee</h2>
        </div>

        <div class="card-body p-5">

            <div class="mb-4">
                <h5 class="mb-0">Are you sure you want to delete this employee?</h5>
            </div>

            @using (Html.BeginForm())
            {
                @Html.HiddenFor(x => x.Id)

                <div class="row g-4">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">First Name</label>

                        <input type="text"
                               class="form-control form-control-lg rounded-3"
                               value="@Model.FirstName"
                               readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Last Name</label>

                        <input type="text"
                               class="form-control form-control-lg rounded-3"
                               value="@Model.LastName"
                               readonly />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Salary</label>

                        <input type="text"
                               class="form-control form-control-lg rounded-3"
                               value="@Model.Salary"
                               readonly />
                    </div>

                </div>

                <div class="mt-5 d-flex gap-3">
                    <input type="submit"
                           value="Delete"
                           class="btn btn-dark btn-lg px-4 rounded-3" />

                    @Html.ActionLink(
                        "Back to List",
                        "Index",
                        null,
                        new
                        {
                            @class = "btn btn-outline-dark btn-lg px-4 rounded-3"
                        })
                </div>
            }

        </div>
    </div>
</div>