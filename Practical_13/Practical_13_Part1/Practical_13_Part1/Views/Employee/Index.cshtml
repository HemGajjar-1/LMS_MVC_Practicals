@{
    ViewBag.Title = "Index";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="mb-0">
            Employee List
        </h2>

        @Html.ActionLink(
            "Create New",
            "Create",
            null,
            new
            {
                @class = "btn btn-dark"
            })

    </div>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-bordered table-hover mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>DOB</th>
                        <th>Age</th>
                        <th>Actions</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.Id</td>

                            <td>@item.Name</td>

                            <td>
                                @item.DOB.ToShortDateString()
                            </td>

                            <td>@item.Age</td>

                            <td>

                                @Html.ActionLink(
                                    "Edit",
                                    "Edit",
                                    new { id = item.Id },
                                    new
                                    {
                                        @class = "btn btn-dark btn-sm me-2"
                                    })

                                @Html.ActionLink(
                                    "Delete",
                                    "Delete",
                                    new { id = item.Id },
                                    new
                                    {
                                        @class = "btn btn-dark btn-sm"
                                    })

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>