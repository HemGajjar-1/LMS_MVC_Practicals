@{
    ViewBag.Title = "Edit";
}

@model Practical_13_Part1.Models.DTOs.UpdateDto

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-header bg-dark text-white">

                    <h4 class="mb-0">
                        Edit Employee
                    </h4>

                </div>

                <div class="card-body">

                    @using (Html.BeginForm())
                    {
                        @Html.HiddenFor(x => x.Id)

                        <div class="mb-3">

                            <label class="form-label">
                                Name
                            </label>

                            @Html.TextBoxFor(
                                x => x.Name,
                                new
                                {
                                    @class = "form-control"
                                })

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                DOB
                            </label>

                            @Html.TextBoxFor(
                                x => x.DOB,
                                new
                                {
                                    @class = "form-control",
                                    type = "date"
                                })

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Age
                            </label>

                            @Html.TextBoxFor(
                                x => x.Age,
                                new
                                {
                                    @class = "form-control"
                                })

                        </div>

                        <div class="text-center">

                            <input type="submit"
                                   value="Update"
                                   class="btn btn-dark" />

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>