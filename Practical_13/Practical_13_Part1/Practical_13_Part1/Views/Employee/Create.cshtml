@{
    ViewBag.Title = "Create";
}

@model Practical_13_Part1.Models.DTOs.CreateDto

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">

                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Create Employee</h4>
                </div>

                <div class="card-body">

                    @using (Html.BeginForm())
                    {
                        <div class="mb-3">

                            <label class="form-label">
                                Name
                            </label>

                            @Html.TextBoxFor(
                                x => x.Name,
                                new
                                {
                                    @class = "form-control"
                                })

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                DOB
                            </label>

                            @Html.TextBoxFor(
                                x => x.DOB,
                                new
                                {
                                    @class = "form-control",
                                    type = "date"
                                })

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Age
                            </label>

                            @Html.TextBoxFor(
                                x => x.Age,
                                new
                                {
                                    @class = "form-control"
                                })

                        </div>

                        <input type="submit"
                               value="Save"
                               class="btn btn-dark" />
                    }

                </div>

            </div>

        </div>

    </div>

</div>