@{
    ViewBag.Title = "Delete";
}

@model Practical_13_Part1.Models.DTOs.DeleteDto

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow border-dark">

                <div class="card-header bg-dark text-white">

                    <h4 class="mb-0">
                        Delete Employee
                    </h4>

                </div>

                <div class="card-body">

                    <h5 class="mb-4">
                        Are you sure?
                    </h5>

                    @using (Html.BeginForm())
                    {
                        @Html.HiddenFor(x => x.Id)

                        <div class="mb-4">

                            <strong>Name:</strong>
                            @Model.Name

                        </div>

                        <div class="d-flex gap-2">

                            <input type="submit"
                                   value="Yes"
                                   class="btn btn-dark" />

                            @Html.ActionLink(
                                "No",
                                "Index",
                                null,
                                new
                                {
                                    @class = "btn btn-dark"
                                })

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>